# Local PostgreSQL
# DATABASE_URL=postgresql://postgres:root@localhost:5432/amigo_invoice_erp

# Supabase (Project Settings → Database → Connection string → Session pooler, port 5432)
# Use database name "postgres". URL-encode password special characters (@ → %40, # → %23).
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

DATABASE_URL=postgresql://postgres:root@localhost:5432/amigo_invoice_erp
SESSION_SECRET=replace-with-long-random-string
CRON_SECRET=replace-with-another-long-random-string
SESSION_MAX_AGE_MS=86400000
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
SEED_SUPERADMIN_EMAIL=owner@yourcompany.com
SEED_SUPERADMIN_PASSWORD=ChangeThisImmediately123
